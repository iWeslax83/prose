# PROSE runs key-free on the built-in deterministic "mock" compiler.
# To compile open-ended intents with an LLM, set a provider + key below.
# If a provider is selected but its key is missing, PROSE falls back to mock.

# mock | groq | xai | openrouter | ollama | gemini
PROSE_PROVIDER=mock

# Optional model override for the selected provider
# PROSE_MODEL=llama-3.3-70b-versatile     # groq
# PROSE_MODEL=grok-2-1212                  # xai (Grok)

# Provider keys (set the one matching PROSE_PROVIDER).
# NOTE: Groq (gsk_...) and xAI Grok (xai-...) are DIFFERENT services.
# GROQ_API_KEY=        # Groq Inc — https://console.groq.com/keys  (key starts gsk_)
# XAI_API_KEY=         # xAI Grok  — https://console.x.ai          (key starts xai-)
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=
# OLLAMA_HOST=http://localhost:11434   # ollama is keyless (local)
